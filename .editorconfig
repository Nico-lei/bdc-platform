root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts,java}]
indent_size = 4
max_line_length = 140

[*.{js,ts,vue,jsx,tsx,json,html,css,scss,less}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false  # 保留 markdown 行尾两空格的硬换行

[*.{bat,cmd,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab
